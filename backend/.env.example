# Database Configuration
# Get this from Render dashboard after creating a PostgreSQL database
DATABASE_URL=postgresql://username:password@host:5432/dbname

# Security - Generate a secure random key (e.g., using python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME

# Backend URL - Used for CORS and generating URLs
# For local development: http://localhost:8000
# For Render: https://your-backend-name.onrender.com
BACKEND_URL=http://localhost:8000

# CORS Origins - Comma-separated list of allowed origins
# For local development: http://localhost:5173,http://127.0.0.1:5173
# For production: https://your-frontend.vercel.app,https://your-frontend.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cloudinary Configuration
# Get these from your Cloudinary dashboard (https://cloudinary.com/)
CLOUDINARY_CLOUD_NAME=dimdroryv
CLOUDINARY_API_KEY=866859645743344
CLOUDINARY_API_SECRET=**********

